<%- include('partials/head', { title: 'Register' }) %>
<%- include('partials/nav', { user }) %>

<main class="form-shell">
  <section class="form-card">
    <h1>Create an account</h1>
    <p class="muted">Pick a username to start reviewing restaurants.</p>

    <% if (typeof error !== 'undefined') { %>
      <p class="alert"><%= error %></p>
    <% } %>

    <form method="post" action="/register">
      <label for="username">Username</label>
      <input id="username" name="username" type="text" placeholder="foodie_izmir" />
      <label for="password">Password</label>
      <input id="password" name="password" type="password" minlength="6" placeholder="6+ characters" />
      <input type="hidden" name="next" value="<%= next %>" />
      <button class="primary" type="submit">Register</button>
    </form>
  <p class="muted">Already have an account? <a class="ghost" href="/login?next=<%= next %>">Log in</a></p>
  </section>
</main>

<%- include('partials/footer') %>
