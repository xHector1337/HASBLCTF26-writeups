<header class="site-header">
  <div class="brand">
    <span class="brand-mark">Anatolian Atlas</span>
    <span class="brand-sub">Restaurant Review Map</span>
  </div>
  <nav>
    <% if (user) { %>
      <span class="user-chip">Hi, <%= user.name %></span>
      <form class="inline-form" method="post" action="/logout">
        <button class="ghost" type="submit">Log out</button>
      </form>
    <% } else { %>
      <a class="ghost" href="/login">Log in</a>
      <a class="primary" href="/register">Register</a>
    <% } %>
  </nav>
</header>
